  "place_to_model_mapping": {
    "_comment": "How to map Nearby Search result fields to Place model fields",
    "place_id":        "result.place_id → Place.placeId (String)",
    "name":            "result.name → Place.name",
    "category":        "result.types[0] → map to app category (see spec.md Section 9.3)",
    "rating":          "result.rating → Place.rating (double, default 0.0)",
    "price_level":     "result.price_level → Place.priceLevel (int, default 0)",
    "address":         "result.vicinity → Place.address",
    "latitude":        "result.geometry.location.lat → Place.latitude",
    "longitude":       "result.geometry.location.lng → Place.longitude",
    "description":     "result.editorial_summary.overview → Place.description (only from Details endpoint)",
    "photo_reference": "result.photos[0].photo_reference → Place.photoReference",
    "open_now":        "result.opening_hours.open_now → Place.openNow (bool → int for SQLite)"
  },

  "google_type_to_app_category": {
